{
  "name": "bookhive-app",
  "version": "1.1.3",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "update:staging": "pnpx eas-cli update --branch staging",
    "update:production": "pnpx eas-cli update --branch production",
    "update:development": "pnpx eas-cli update --branch development",
    "ios:build": "bun run bump && pnpx eas-cli build --platform ios",
    "ios:submit": "pnpx eas-cli submit --platform ios",
    "bump": "bun run scripts/bump-version.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "~15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.0.14",
    "@tanstack/query-async-storage-persister": "^5.90.12",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-persist-client": "^5.90.12",
    "date-fns": "^3.6.0",
    "expo": "~55.0.9",
    "expo-application": "~55.0.10",
    "expo-blur": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-updates": "~55.0.16",
    "expo-web-browser": "~55.0.10",
    "ofetch": "1.4.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "cosmiconfig": "5.2.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.11",
    "react-test-renderer": "^19.2.0"
  },
  "jest": {
    "preset": "jest-expo"
  }
