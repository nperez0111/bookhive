{
  "name": "bookhive-app",
  "version": "1.2.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "update:staging": "pnpx eas-cli update --branch staging",
    "update:production": "pnpx eas-cli update --branch production",
    "update:development": "pnpx eas-cli update --branch development",
    "ios:build": "bun run bump && EAS_BUILD_NO_EXPO_GO_WARNING=true pnpx eas-cli build --platform ios",
    "ios:submit": "pnpx eas-cli submit --platform ios",
    "bump": "bun run scripts/bump-version.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "~15.1.1",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.17",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/query-async-storage-persister": "^5.100.10",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-persist-client": "^5.100.10",
    "date-fns": "^4.4.0",
    "expo": "~56.0.8",
    "expo-application": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "ofetch": "1.5.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~3.0.0",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.9.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.16",
    "@types/react-test-renderer": "19.1.0",
    "cosmiconfig": "9.0.1",
    "jest": "30.4.2",
    "jest-expo": "56.0.4",
    "react-test-renderer": "19.2.7"
  },
  "jest": {
    "preset": "jest-expo"
  }
}
