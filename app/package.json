{
  "name": "bookhive-app",
  "version": "1.1.4",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "update:staging": "pnpx eas-cli update --branch staging",
    "update:production": "pnpx eas-cli update --branch production",
    "update:development": "pnpx eas-cli update --branch development",
    "ios:build": "bun run bump && pnpx eas-cli build --platform ios",
    "ios:submit": "pnpx eas-cli submit --platform ios",
    "bump": "bun run scripts/bump-version.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "~15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.17",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/query-async-storage-persister": "^5.100.10",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-persist-client": "^5.100.10",
    "date-fns": "^4.1.0",
    "expo": "~55.0.24",
    "expo-application": "~55.0.15",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.22",
    "expo-web-browser": "~55.0.16",
    "ofetch": "1.5.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "typescript": "^5.9.3"
