    "@types/react-test-renderer": "19.1.0",
    "cosmiconfig": "5.2.1",
    "jest": "29.7.0",
    "jest-expo": "55.0.17",
    "react-test-renderer": "19.2.6"
  },
  "jest": {
    "preset": "jest-expo"
  }
