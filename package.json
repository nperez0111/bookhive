    "tailwindcss": "^4.1.18",
    "tailwindcss-animated": "^2.0.0",
    "typescript": "^6.0.3",
    "unstorage": "1.17.5",
    "vite": "^8.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "patchedDependencies": {
    "@atcute/oauth-crypto@0.1.0": "patches/@atcute%2Foauth-crypto@0.1.0.patch"
  }
}
