{
  "name": "bookhive",
  "private": true,
  "workspaces": [
    "app"
  ],
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "seed:db": "bun run src/initialize.ts",
    "dev": "bunx --bun vp dev",
    "build": "bun --bun run lexgen && bunx --bun vp build",
    "preview": "bun run .output/server/index.mjs",
    "test": "bun test src",
    "test:run": "bun test src --no-watch",
    "lint": "vp lint src --type-aware --type-check && vp fmt --write",
    "typecheck": "vp lint src --type-aware --type-check && vp fmt --write",
    "format": "vp fmt",
    "lexgen": "lex-cli generate",
    "postlexgen": "vp fmt ./src/bsky/lexicon/",
    "start": "bun run .output/server/index.mjs",
    "ios": "bun run --cwd app ios",
    "android": "bun run --cwd app android",
    "ios:build": "bun run --cwd app ios:build",
    "ios:submit": "bun run --cwd app ios:submit",
    "prepare": "vp config"
  },
  "dependencies": {
    "@atcute/password-session": "1.0.2",
    "@atcute/xrpc-server": "2.0.2",
    "@takumi-rs/image-response": "2.2.2",
    "@voidzero-dev/vite-plus-core": "0.2.4",
    "basecoat-css": "1.0.2",
    "ocache": "0.2.0",
    "pino": "10.3.1",
    "react": "19.2.7",
    "srvx": "0.11.22",
    "takumi-js": "2.2.2"
  },
  "devDependencies": {
    "@atcute/atproto": "4.0.3",
    "@atcute/bluesky": "4.0.14",
    "@atcute/client": "5.1.1",
    "@atcute/identity-resolver": "2.0.1",
    "@atcute/identity-resolver-node": "2.0.1",
    "@atcute/jetstream": "2.0.2",
    "@atcute/lex-cli": "3.2.1",
    "@atcute/lexicons": "2.0.3",
    "@atcute/oauth-node-client": "2.0.1",
    "@atcute/repo": "1.0.2",
    "@atcute/tid": "1.1.4",
    "@hono/prometheus": "1.0.3",
    "@hono/zod-validator": "0.9.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.78.0",
