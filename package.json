    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/vite": "4.3.3",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "latest",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "csv-parse": "7.0.1",
