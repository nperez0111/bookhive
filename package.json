{
  "name": "bookhive",
  "private": true,
  "workspaces": [
    "app"
  ],
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "seed:db": "bun run src/initialize.ts",
    "dev": "bunx --bun vite",
    "build": "bun --bun run lexgen && bunx --bun vite build",
    "preview": "bun run .output/server/index.mjs",
    "test": "bun test src",
    "test:run": "bun test src --no-watch",
    "lint": "oxlint src --type-aware --type-check && oxfmt --write",
    "typecheck": "oxlint src --type-aware --type-check && oxfmt --write",
    "format": "oxfmt",
    "lexgen": "lex-cli generate",
    "postlexgen": "oxfmt ./src/bsky/lexicon/",
    "start": "bun run .output/server/index.mjs",
    "ios": "bun run --cwd app ios",
    "android": "bun run --cwd app android",
    "ios:build": "bun run --cwd app ios:build",
    "ios:submit": "bun run --cwd app ios:submit"
  },
  "dependencies": {
    "@atcute/xrpc-server": "2.0.0",
    "@takumi-rs/image-response": "1.3.0",
    "@tanstack/hotkeys": "0.8.0",
    "basecoat-css": "0.3.11",
    "nf3": "0.3.17",
    "ocache": "0.1.4",
    "pino": "^10.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "takumi-js": "1.3.0"
  },
  "devDependencies": {
    "@atcute/atproto": "4.0.0",
    "@atcute/bluesky": "^4.0.2",
    "@atcute/car": "6.0.0",
    "@atcute/client": "^5.0.0",
    "@atcute/identity-resolver": "2.0.0",
    "@atcute/identity-resolver-node": "2.0.0",
    "@atcute/jetstream": "^2.0.0",
    "@atcute/lex-cli": "3.1.0",
    "@atcute/lexicons": "2.0.0",
    "@atcute/oauth-node-client": "^2.0.0",
    "@atcute/tid": "1.1.2",
    "@hono/prometheus": "^1.0.2",
    "@hono/zod-validator": "^0.8.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@tailwindcss/cli": "4.3.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "4.3.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "latest",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/shimmer": "^1.2.0",
    "csv-parse": "6.2.1",
    "date-fns": "4.2.1",
    "envalid": "^8.1.1",
    "hono": "^4.11.9",
    "iron-session": "^8.0.4",
    "kysely": "^0.29.2",
    "nitro": "npm:nitro-nightly@3.0.1-20260512-093145-0498ce70",
    "ohash": "2.0.11",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
